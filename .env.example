# Database — SQLite
DATABASE_URL=sqlite:///./data/agent.db

# Vikunja
VIKUNJA_API_TOKEN=your-vikunja-api-token
VIKUNJA_JWT_SECRET=your-vikunja-jwt-secret
# Public URL for Vikunja — only needed if you expose it via nginx
VIKUNJA_SERVICE_PUBLICURL=https://tasks.epicrunze.com

# LLM — Phase 1: Gemini only
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Ollama — Phase 2
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:4b

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
ALLOWED_EMAIL=your.email@gmail.com
# OAuth redirect must match: https://api-cognito.epicrunze.com/api/auth/google/callback

# Google Calendar — Phase 3
# GCAL_CALENDAR_ID=primary

# JWT
JWT_SECRET=change-me-in-production

# URLs — production
FRONTEND_URL=https://cognito.epicrunze.com
BACKEND_URL=https://api-cognito.epicrunze.com

# Cookie — auth cookie is shared across *.epicrunze.com subdomains
COOKIE_DOMAIN=.epicrunze.com
